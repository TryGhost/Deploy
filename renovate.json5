{
    extends: ['local>TryGhost/renovate-config'],
    packageRules: [
        {
            description: 'Keep pnpm on 10.x while this repo supports Node 20.20.0; pnpm 11 requires Node 22.13 or newer.',
            matchPackageNames: ['pnpm'],
            allowedVersions: '<11',
        },
        {
            description: 'Keep CI runtime jobs pinned to Node 20.20.0; this is the lowest consumer runtime and must not drift to patch releases.',
            matchManagers: ['github-actions'],
            matchDepNames: ['node'],
            matchCurrentValue: '20.20.0',
            allowedVersions: '20.20.0',
        },
    ],
}
