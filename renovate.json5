{
    extends: ['local>TryGhost/renovate-config'],
    packageRules: [
        {
            description: 'Keep pnpm on 10.x while this repo supports Node 20.20.0; pnpm 11 requires Node 22.13 or newer.',
            matchPackageNames: ['pnpm'],
            allowedVersions: '<11',
        },
    ],
}
