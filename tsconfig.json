{
  "compilerOptions": {
    "target": "ES2023",
    "module": "node20",
    "moduleResolution": "node16",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
